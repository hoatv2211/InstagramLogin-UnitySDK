# ===== INSTAGRAM APP CONFIG =====
# Get from: https://developers.facebook.com/apps/
# Go to Instagram product → API Settings with Instagram Login
INSTAGRAM_CLIENT_ID=your_instagram_app_id_here
INSTAGRAM_CLIENT_SECRET=your_instagram_app_secret_here

# ===== SERVER CONFIG =====
PORT=3000
# Local dev: http://localhost:3000
# Production: https://your-project.vercel.app
SERVER_URL=http://localhost:3000

# ===== SECURITY =====
# Generate with: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=your_super_secret_jwt_key_change_this_in_production
SESSION_SECRET=your_session_secret_key

# ===== UNITY CALLBACK =====
# Choose 1 mode: deeplink | polling | websocket | webgl
# NOTE: Use "polling" on Vercel — WebSocket is NOT supported on serverless
CALLBACK_MODE=polling

# Deep link scheme for Unity app (Android/iOS)
UNITY_DEEP_LINK_SCHEME=myunityapp

# Redirect URL for WebGL build
UNITY_WEBGL_URL=http://localhost:8080

# ===== CORS =====
# Comma-separated list of allowed origins
ALLOWED_ORIGINS=http://localhost:8080,http://localhost:3000,https://your-domain-here.vercel.app

# ===== UPSTASH REDIS (required on Vercel for polling mode, skip for local dev) =====
# Set up: Vercel Dashboard → Integrations → Search "Upstash" → Add Redis
# After connecting, these vars are auto-injected by Vercel.
# For local testing, copy values from Upstash Console → REST API.
UPSTASH_REDIS_REST_URL=https://your-upstash-url.upstash.io
UPSTASH_REDIS_REST_TOKEN=your_upstash_rest_token_here
